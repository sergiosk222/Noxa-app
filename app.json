{
  "expo": {
    "name": "Noxa",
    "slug": "Noxa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "noxa",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karaketidis.noxa",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.karaketidis.noxa",
      "adaptiveIcon": {
        "backgroundColor": "#C8102E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/noxa-splash-logo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#C8102E",
          "dark": {
            "image": "./assets/images/noxa-splash-logo.png",
            "backgroundColor": "#C8102E"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NOXA uses your precise location to place you on the live map while the app is open.",
          "locationAlwaysAndWhenInUsePermission": "NOXA uses your precise location during a 4-hour Live Drive session, including in the background, so the audience you choose can see you on the live map.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "splash": {
      "image": "./assets/images/noxa-splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#C8102E"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8c32a4c3-2d1f-4f1d-abba-0209cfeecb3a"
      }
    },
    "owner": "noxastreetapp"
  }
}
