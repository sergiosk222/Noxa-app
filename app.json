{
  "expo": {
    "name": "Noxa",
    "slug": "Noxa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "noxa",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karaketidis.noxa"
    },
    "android": {
      "package": "com.karaketidis.noxa",
      "adaptiveIcon": {
        "backgroundColor": "#C8102E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080A0F",
          "dark": {
            "backgroundColor": "#080A0F"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "NOXA uses your precise location to place you on the live map while the app is open.",
          "locationAlwaysAndWhenInUsePermission": "NOXA uses your precise location during a 4-hour Live Drive session, including in the background, so the audience you choose can see you on the live map.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "splash": {
      "backgroundColor": "#080A0F"
    }
  }
}
